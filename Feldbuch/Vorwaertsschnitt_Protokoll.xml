<?xml version="1.0" encoding="utf-8"?>
<Protokoll modul="Vorwaertsschnitt">

  <Seite breite="210" hoehe="297" randLinks="20" randRechts="20" randOben="20" randUnten="20"/>

  <Schriften>
    <Schrift id="0" name="Arial Narrow" typ="swiss"/>
    <Schrift id="1" name="Courier New"  typ="modern"/>
  </Schriften>

  <!-- cf1=Blau  cf2=Orange (5–20 cc)  cf3=Rot (20–60 cc)  cf4=Tiefrot (>60 cc) -->
  <Farben>
    <Farbe r="42"  g="72"  b="130"/>
    <Farbe r="200" g="100" b="0"/>
    <Farbe r="180" g="30"  b="30"/>
    <Farbe r="140" g="0"   b="0"/>
  </Farben>

  <Inhalt>

    <!-- ── Titelzeile ─────────────────────────────────────────────────────── -->
    <Abschnitt typ="Titel" schrift="0" groesse="13" fett="true" unterlinie="true" abstandNach="80">
      <Feld text="Vorwärtschnitt"/>
      <Feld text="     Beobachter: "/>
      <Feld var="Bearbeiter"/>
      <Feld text="     Datum/Uhrzeit:  "/>
      <Feld var="Zeitpunkt"/>
    </Abschnitt>

    <!-- ── Neupunkt ───────────────────────────────────────────────────────── -->
    <Abschnitt typ="Zeile" schrift="1" groesse="10" abstandNach="40">
      <Feld var="Neupunkt" label="Neupunkt-Nr.:  "/>
    </Abschnitt>

    <Abschnitt typ="Leerzeile" schrift="1" groesse="8"/>

    <!-- ── Beobachtungstabelle ────────────────────────────────────────────── -->
    <!-- Spalten: PunktNr(Station) | R | H | Hz | z | t | s | v -->
    <Abschnitt typ="Tabelle" schrift="1" groesse="8" kopfFett="true" ampel="true">
      <Spalte var="PunktNr" header="Station"   breite="10" ausrichtung="L"/>
      <Spalte var="R"       header="R [m]"     breite="12" ausrichtung="R"/>
      <Spalte var="H"       header="H [m]"     breite="12" ausrichtung="R"/>
      <Spalte var="Hz"      header="Hz [gon]"  breite="10" ausrichtung="R"/>
      <Spalte var="z"       header="z [gon]"   breite="10" ausrichtung="R"/>
      <Spalte var="t"       header="t [gon]"   breite="10" ausrichtung="R"/>
      <Spalte var="s"       header="s [m]"     breite="9"  ausrichtung="R"/>
      <Spalte var="v"       header="v [cc]"    breite="8"  ausrichtung="R"/>
    </Abschnitt>

    <Abschnitt typ="Leerzeile" schrift="1" groesse="10"/>

    <!-- ── Ergebnis ───────────────────────────────────────────────────────── -->
    <Abschnitt typ="Zeile" schrift="1" groesse="10" fett="true" abstandNach="40">
      <Feld var="R" label="Rechtswert:  " einheit=" m"/>
      <Feld text="    "/>
      <Feld var="H" label="Hochwert:    " einheit=" m"/>
    </Abschnitt>

    <Abschnitt typ="Zeile" schrift="1" groesse="10" unterlinie="true" abstandNach="80">
      <Feld var="S0Info"/>
    </Abschnitt>

  </Inhalt>

</Protokoll>
