<Window x:Class="MangelManager.Views.KameraCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Foto aufnehmen"
        Height="580" Width="740"
        MinHeight="480" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="CanResize">

    <DockPanel Margin="10">

        <!-- Kamera-Auswahl -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Kamera:" Foreground="#90CAF9" VerticalAlignment="Center"
                       Margin="0,0,10,0" FontSize="13"/>
            <ComboBox x:Name="KameraAuswahl" Grid.Column="1"
                      SelectionChanged="KameraAuswahl_SelectionChanged"
                      Background="#263238" Foreground="White"
                      BorderBrush="#37474F" FontSize="13"/>
        </Grid>

        <!-- Buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusText" Grid.Column="0"
                       Foreground="#90CAF9" FontSize="12"
                       VerticalAlignment="Center"
                       Text="Kamera wird initialisiert..."/>

            <Button x:Name="AufnehmenBtn" Grid.Column="1"
                    Content="  Aufnehmen  "
                    Click="Aufnehmen_Click"
                    IsEnabled="False"
                    FontSize="15" FontWeight="Bold"
                    Padding="20,8" BorderThickness="0"
                    Cursor="Hand" Foreground="White">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#43A047"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#546E7A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Column="3"
                    Content="Abbrechen"
                    Click="Abbrechen_Click"
                    FontSize="13" Padding="16,8" BorderThickness="0"
                    Foreground="White" Background="#546E7A" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Vorschau -->
        <Border BorderBrush="#37474F" BorderThickness="2" Background="#000000">
            <Grid>
                <Image x:Name="PreviewImage" Stretch="Uniform"/>
                <!-- Overlay-Text wenn noch kein Bild -->
                <TextBlock x:Name="NoBildText"
                           Text="Warte auf Kamera..." Foreground="#546E7A"
                           FontSize="18" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </DockPanel>
</Window>
